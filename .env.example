# ---------------------------------------------------------------------------
# Supabase — required. Create a project at https://supabase.com, then run
# supabase/migrations/0001_init.sql in the SQL editor before starting the app.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Mapbox — optional. Without this, MapView renders a stylized mock map
# instead of live Mapbox tiles — the app never shows a broken map.
# Get a token at https://account.mapbox.com/access-tokens
# ---------------------------------------------------------------------------
VITE_MAPBOX_TOKEN=

# ---------------------------------------------------------------------------
# Gemini — required for the AI Route Explanation feature. This key is NEVER
# read client-side; it's set as a Supabase Edge Function secret, not a
# VITE_ variable, so it never ships in the browser bundle:
#
#   supabase secrets set GEMINI_API_KEY=your-key-here
#   supabase functions deploy route-explanation
#
# Get a key at https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
